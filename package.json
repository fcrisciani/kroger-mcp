{
  "name": "kroger-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Personal MCP server for the Kroger Public API, deployed as a Cloudflare Worker.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "kv:create": "wrangler kv namespace create OAUTH_KV && wrangler kv namespace create KROGER_KV"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.0.5",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "agents": "^0.0.67",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
